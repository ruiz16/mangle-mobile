# =============================================================================
# Mangle — Frontend (Vite) — variables de entorno
# Renombrá este archivo a `.env` y completá los valores.
# TODAS son requeridas (network.ts las valida con requireEnv).
# =============================================================================

# Red activa en compile-time: sepolia | mainnet
VITE_CELO_NETWORK=sepolia

# Base de la API (backend Next.js)
VITE_API_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Celo Sepolia (testnet) — la que usa MiniPay en Developer Mode > Use Testnet
# -----------------------------------------------------------------------------
VITE_CELO_SEPOLIA_RPC=https://forno.celo-sepolia.celo-testnet.org
# RPCs extra opcionales, separados por coma (redundancia). Dejar vacío si no hay.
VITE_CELO_SEPOLIA_RPC_FALLBACKS=

# MockCopm en testnet (sos owner → mint libre). El token de pago NO necesita ser
# fee currency: MiniPay paga el GAS en USDm aparte. DEBE coincidir EXACTO con el
# copm() del LendingPool de abajo, o el repay revierte (mismatch de token).
VITE_COPM_SEPOLIA=0x6C732d66805da10bdd76F00bd05EA9eF9E66577f

# Slot legacy (el proyecto migró de cUSD a COPm). USDm de Mento en Sepolia.
VITE_CUSD_SEPOLIA=0xdE9e4C3ce781b4bA68120d6261cbad65ce0aB00b

# LendingPool de testnet REDESPLEGADO apuntando al MOCK de arriba (copm es immutable).
# ⚠️ Reemplazar por la address del pool-mock nuevo tras redeployar.
VITE_LENDING_POOL_SEPOLIA=0xTU_LENDING_POOL_MOCK_SEPOLIA

# -----------------------------------------------------------------------------
# Celo Mainnet (producción)
# -----------------------------------------------------------------------------
VITE_CELO_MAINNET_RPC=https://forno.celo.org
VITE_CELO_MAINNET_RPC_FALLBACKS=

# cCOP — peso colombiano de Mento, fee currency registrado en mainnet.
VITE_COPM_MAINNET=0x8A567e2aE79CA692Bd748aB832081C45de4041eA

# cUSD mainnet (slot legacy).
VITE_CUSD_MAINNET=0x765DE816845861e75A25fCA122bb6898B8B1282a

VITE_LENDING_POOL_MAINNET=0xTU_LENDING_POOL_MAINNET
