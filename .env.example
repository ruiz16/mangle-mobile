# =============================================================================
# MANGLE Mini App — Environment Variables
# =============================================================================
# Copia este archivo como .env.local y completa los valores.
#
# ⚠️ TODAS las variables son REQUERIDAS. No hay defaults quemados.
# Si falta alguna, la app tira error al iniciar.
# =============================================================================

# ── Network selection ──────────────────────────────────────────────
# Elegi UNA:
VITE_CELO_NETWORK=sepolia
# VITE_CELO_NETWORK=mainnet

# ── RPC Endpoints ───────────────────────────────────────────
VITE_CELO_MAINNET_RPC=https://forno.celo.org
VITE_CELO_SEPOLIA_RPC=https://forno.celo-sepolia.celo-testnet.org

# ── COPm (Moneda Local de Confianza) ────────────────────────
# Mainnet:
VITE_COPM_MAINNET=0x8A567e2aE79CA692Bd748aB832081C45de4041eA
# Sepolia:
VITE_COPM_SEPOLIA=0x5F8d55c3627d2dc0a2B4afa798f877242F382F67

# ── cUSD (Mento Dollar) ───────────────────────────────────
# Mainnet:
VITE_CUSD_MAINNET=0x765DE816845861e75A25fCA122bb6898B8B1282a
# Sepolia:
VITE_CUSD_SEPOLIA=0xdE9e4C3ce781b4bA68120d6261cbad65ce0aB00b

# ── API ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000

# ── LendingPool (escrow de fondos COPm) ───────────────────
# Desplegar con mangle-app/scripts/deploy-lending-pool.mjs y pegar la direccion.
# Mainnet:
VITE_LENDING_POOL_MAINNET=0x0000000000000000000000000000000000000000
# Sepolia:
VITE_LENDING_POOL_SEPOLIA=0x0000000000000000000000000000000000000000
